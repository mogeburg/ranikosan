---
import FanartCard from "./FanartCard.astro";
import type { Fanart } from "../data/fanarts";

interface Props {
  fanarts: Fanart[];
  base: string;
}

const { fanarts, base } = Astro.props;
---

<div class="grid">
  {
    fanarts.map((fanart) => (
      <FanartCard fanart={fanart} base={base} />
    ))
  }
</div>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-sm);
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.5rem;
    }
  }

  @media (max-width: 480px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
