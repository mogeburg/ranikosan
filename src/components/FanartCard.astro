---
import type { Fanart } from "../data/fanarts";

interface Props {
  fanart: Fanart;
  base: string;
}

const { fanart, base } = Astro.props;
const imgUrl = `${base}/${fanart.imagePath}`;
const isYoutube =
  fanart.relatedUrl?.includes("youtube.com") ||
  fanart.relatedUrl?.includes("youtu.be");
const linkLabel = fanart.relatedUrl ? (isYoutube ? "配信URL" : "元URL") : null;
const tagsAttr = fanart.tags.join(" ");
---

<article
  class="card"
  data-sensitive={fanart.sensitive ? "true" : undefined}
  data-tags={tagsAttr}
>
  <div class="card-image-wrapper">
    <a href={imgUrl} target="_blank" class="card-image-link">
      <img src={imgUrl} loading="lazy" decoding="async" alt="" />
    </a>
    {
      fanart.sensitive && (
        <div class="blur-overlay">
          <span class="blur-overlay-note">センシティブな内容を含みます</span>
          <span class="blur-overlay-text">クリックで表示</span>
        </div>
      )
    }
  </div>
  <div class="card-meta">
    <span class="card-author">{fanart.author || "もげ"}</span>
    <time class="card-date">{fanart.postedAt}</time>
    {
      linkLabel && (
        <a
          href={fanart.relatedUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="card-link"
        >
          {linkLabel}
        </a>
      )
    }
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-image);
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .card-image-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--color-border);
  }

  .card-image-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .card-image-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: filter var(--transition-fast);
  }

  .card[data-sensitive="true"] .card-image-link img {
    filter: blur(24px);
  }

  .card[data-sensitive="true"] .blur-overlay {
    display: flex;
  }

  :global(html[data-sensitive-shown])
    .card[data-sensitive="true"]
    .card-image-link
    img {
    filter: none;
  }

  :global(html[data-sensitive-shown])
    .card[data-sensitive="true"]
    .blur-overlay {
    display: none;
  }

  .blur-overlay {
    display: none;
    position: absolute;
    inset: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.35);
    gap: 0.5rem;
    cursor: pointer;
    z-index: 1;
    user-select: none;
  }

  .blur-overlay-note {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.75rem;
    text-align: center;
  }

  .blur-overlay-text {
    color: #fff;
    font-size: 0.875rem;
    padding: 0.375rem 0.75rem;
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.55);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
  }

  .card-author {
    font-weight: 600;
    flex-shrink: 0;
  }

  .card-date {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .card-link {
    font-size: 0.75rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  .card-link:hover {
    text-decoration: underline;
  }
</style>
