---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'らにこさんの個人ホームページ' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}/images/favicon.ico`} />
    <title>{title}</title>
    <script is:inline>
      (function(){var k='otegaki-sensitive';if(localStorage.getItem(k)==='true'){document.documentElement.dataset.sensitiveShown='';}})();
    </script>
  </head>
  <body>
    <Navbar />
    <main class="container">
      <slot />
    </main>
  </body>
</html>

<style>
  .container {
    width: 100%;
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: calc(var(--space-lg) + 3rem) var(--content-padding) var(--space-lg);
  }

  @media (max-width: 768px) {
    .container {
      padding: calc(var(--space-md) + 3rem) var(--content-padding) var(--space-md);
    }
  }
</style>
