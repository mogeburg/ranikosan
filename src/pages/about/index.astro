---
import Heading from "../../components/Heading.astro";
import ImageModal from "../../components/ImageModal.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const raniko001 = `${base}/images/raniko001.png`;
const raniko002 = `${base}/images/raniko002.png`;
---

<BaseLayout title="らにこさんについて | らにこさんのホームページ">
  <div class="page">
    <section class="section">
      <Heading tag="h1" class="section-title">なにココ</Heading>
      <p class="section-text">
        らにこさんのホームページです。らにこさんについてのことや、絵・リンク。描いて頂いたファンアートなどが見れます。
      </p>
    </section>

    <section class="section">
      <Heading tag="h2" class="section-title">らにこさんとは</Heading>
      <p class="section-text">
        らにこさんだよ。らにこでもらにこちゃでもﾗﾆｺﾀｿでも好きに呼んでね。主にTwitchでゲームとかお絵かきの配信をしているよ。好きなものは唐揚げとウイスキーだよ、よろしくね。
      </p>
      <ul class="social-links">
        <li>
          <a
            href="https://x.com/mogemogeburg"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path></svg
            >
            X
          </a>
        </li>
        <li>
          <a
            href="https://www.twitch.tv/mogemogeburg"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"
              ></path></svg
            >
            Twitch
          </a>
        </li>
        <li>
          <a
            href="https://www.youtube.com/@%E3%82%89%E3%81%AB%E3%81%93%E3%81%95%E3%82%93"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
              ></path></svg
            >
            YouTube
          </a>
        </li>
      </ul>
    </section>

    <section class="section">
      <Heading tag="h2" class="section-title">資料集</Heading>
      <div class="illust-grid">
        <figure class="illust-figure">
          <img src={raniko001} alt="立ち絵" class="illust-img" />
          <figcaption class="illust-caption">立ち絵</figcaption>
        </figure>
        <figure class="illust-figure">
          <img src={raniko002} alt="作画資料" class="illust-img" />
          <figcaption class="illust-caption">作画について</figcaption>
        </figure>
      </div>
    </section>
  </div>

  <ImageModal />
</BaseLayout>

<script>
  const grid = document.querySelector(".illust-grid");
  if (grid) {
    grid.addEventListener("click", (e) => {
      const img = (e.target as HTMLElement).closest(
        ".illust-img",
      ) as HTMLImageElement;
      if (!img) return;

      const images = Array.from(
        document.querySelectorAll<HTMLImageElement>(".illust-img"),
      ).map((i) => ({ url: i.src, sensitive: false }));

      const index = images.findIndex((i) => i.url === img.src);
      if (index === -1) return;

      (window as any).ImageModal.open(images, index);
    });
  }
</script>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .section-title {
    font-size: 1.5rem;
  }

  .section-text {
    margin: 0;
    line-height: 1.8;
  }

  .social-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .social-link:hover {
    border-color: var(--color-accent);
    background: var(--color-surface);
    text-decoration: none;
  }

  .illust-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
  }

  .illust-figure {
    margin: 0;
    border-radius: var(--radius-image);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-border);
  }

  .illust-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 4;
    object-fit: contain;
    background: var(--color-surface);
    cursor: pointer;
  }

  .illust-caption {
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (max-width: 768px) {
    .page {
      gap: var(--space-md);
    }

    .illust-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
