---
import Heading from "../../components/Heading.astro";
import ImageModal from "../../components/ImageModal.astro";
import SocialLinks from "../../components/SocialLinks.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const raniko001 = `${base}/images/raniko001.png`;
const raniko002 = `${base}/images/raniko002.png`;
---

<BaseLayout title="らにこさんについて | らにこさんのホームページ">
  <div class="page">
    <section class="section">
      <Heading tag="h1" class="section-title">なにココ</Heading>
      <p class="section-text">
        らにこさんのホームページです。らにこさんについてのことや、絵・リンク。描いて頂いたファンアートなどが見れます。
      </p>
    </section>

    <section class="section">
      <Heading tag="h2" class="section-title">らにこさんとは</Heading>
      <p class="section-text">
        らにこさんだよ。らにこでもらにこちゃでもﾗﾆｺﾀｿでも好きに呼んでね。主にTwitchでゲームとかお絵かきの配信をしているよ。好きなものは唐揚げとウイスキーだよ、よろしくね。
      </p>
      <SocialLinks variant="pill" />
    </section>

    <section class="section">
      <Heading tag="h2" class="section-title">資料集</Heading>
      <div class="illust-grid">
        <figure class="illust-figure">
          <img src={raniko001} alt="立ち絵" class="illust-img" />
          <figcaption class="illust-caption">立ち絵</figcaption>
        </figure>
        <figure class="illust-figure">
          <img src={raniko002} alt="作画資料" class="illust-img" />
          <figcaption class="illust-caption">作画について</figcaption>
        </figure>
      </div>
    </section>
  </div>

  <ImageModal />
</BaseLayout>

<script>
  const grid = document.querySelector(".illust-grid");
  if (grid) {
    grid.addEventListener("click", (e) => {
      const img = (e.target as HTMLElement).closest(
        ".illust-img",
      ) as HTMLImageElement;
      if (!img) return;

      const images = Array.from(
        document.querySelectorAll<HTMLImageElement>(".illust-img"),
      ).map((i) => ({ url: i.src, sensitive: false }));

      const index = images.findIndex((i) => i.url === img.src);
      if (index === -1) return;

      (window as any).ImageModal.open(images, index);
    });
  }
</script>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .section-title {
    font-size: 1.5rem;
  }

  .section-text {
    margin: 0;
    line-height: 1.8;
  }

  .illust-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
  }

  .illust-figure {
    margin: 0;
    border-radius: var(--radius-image);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-border);
  }

  .illust-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 4;
    object-fit: contain;
    background: var(--color-surface);
    cursor: pointer;
  }

  .illust-caption {
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (max-width: 768px) {
    .page {
      gap: var(--space-md);
    }

    .illust-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
