---
import ImageModal from "../components/ImageModal.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const topImg = `${base}/images/top.png`;
---

<BaseLayout title="らにこさんのホームページ">
  <div class="page">
    <div class="hero">
      <a href={`${base}/otegaki/`} class="hero-link">
        <img src={topImg} alt="らにこさんトップ画像" class="hero-image" />
      </a>
    </div>
  </div>

  <ImageModal />
</BaseLayout>

<style>
  .page {
    min-height: calc(100vh - var(--space-lg) * 2 - 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .hero {
    text-align: center;
  }

  .hero-link {
    display: inline-block;
    max-width: 720px;
    width: 100%;
  }

  .hero-image {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    transition: opacity var(--transition-fast);
  }

  .hero-link:hover .hero-image {
    opacity: 0.85;
    text-decoration: none;
  }

  .page :global(.variant-round) {
    margin-top: var(--space-md);
  }

  @media (max-width: 768px) {
    .page {
      min-height: calc(100vh - var(--space-md) * 2 - 3rem);
    }
  }
</style>
