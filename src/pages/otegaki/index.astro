---
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="おてがき | らにこさんのホームページ">
  <h1 class="page-title">おてがき</h1>
  <p class="caption">描いて頂いた絵をまとめています。ありがとうございます！</p>
  <p>工事中…</p>
</BaseLayout>

<style>
  .page-title {
    font-size: 2.5rem;
    margin: 0;
  }

  .caption {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0.25rem 0 0;
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2rem;
    }
  }
</style>
