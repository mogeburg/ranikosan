---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FanartGrid from "../../components/FanartGrid.astro";
import ImageModal from "../../components/ImageModal.astro";
import Heading from "../../components/Heading.astro";
import { fanarts } from "../../data/fanarts";

const base = import.meta.env.BASE_URL;
const tags = [...new Set(fanarts.flatMap((f) => f.tags))];
---

<BaseLayout title="おてがき | らにこさんのホームページ">
  <Heading tag="h1" class="page-title">おてがき</Heading>
  <p class="caption">描いて頂いた絵をまとめています。ありがとうございます！</p>

  <div class="controls">
    <label class="sensitive-checkbox">
      <input type="checkbox" id="sensitive-toggle" />
      センシティブな画像を表示
    </label>

    <div class="filter-tabs" role="tablist" aria-label="タグで絞り込み">
      <button class="filter-tab active" data-tag="all" role="tab" aria-selected="true">
        すべて
      </button>
      {tags.map((tag) => (
        <button class="filter-tab" data-tag={tag} role="tab" aria-selected="false">
          {tag}
        </button>
      ))}
    </div>
  </div>

  <FanartGrid fanarts={fanarts} base={base} />

  <ImageModal />
</BaseLayout>

<script>
  const STORAGE_KEY = "otegaki-sensitive";

  function init() {
    const grid = document.querySelector(".grid");
    if (!grid) return;

    const sensitiveCheckbox = document.getElementById(
      "sensitive-toggle"
    ) as HTMLInputElement;
    const filterTabs = document.querySelector(".filter-tabs") as HTMLElement;
    const allCards = () =>
      Array.from(grid.querySelectorAll(".card")) as HTMLElement[];

    // --- Sensitive toggle ---
    function setSensitiveState(show: boolean) {
      if (show) {
        document.documentElement.dataset.sensitiveShown = "";
      } else {
        delete document.documentElement.dataset.sensitiveShown;
      }
    }

    const initialShown = document.documentElement.dataset.sensitiveShown !== undefined;
    sensitiveCheckbox.checked = initialShown;

    sensitiveCheckbox.addEventListener("change", () => {
      localStorage.setItem(STORAGE_KEY, String(sensitiveCheckbox.checked));
      setSensitiveState(sensitiveCheckbox.checked);
    });

    // --- Grid click delegation ---
    grid.addEventListener("click", (e) => {
      const overlay = (e.target as HTMLElement).closest(".blur-overlay");

      // Blur overlay → toggle global sensitive state
      if (overlay) {
        sensitiveCheckbox.checked = true;
        localStorage.setItem(STORAGE_KEY, "true");
        setSensitiveState(true);
        return;
      }

      // Image area → open modal
      const imageWrapper = (e.target as HTMLElement).closest(".card-image-wrapper");
      if (!imageWrapper) return;

      const card = imageWrapper.closest(".card") as HTMLElement;
      if (!card) return;

      const visibleCards = Array.from(
        grid.querySelectorAll<HTMLElement>(".card")
      ).filter((c) => c.style.display !== "none");

      const index = visibleCards.indexOf(card);
      if (index === -1) return;

      const images = visibleCards.map((c) => {
        const img = c.querySelector<HTMLImageElement>(".card-image-link img")!;
        return {
          url: img.src,
          sensitive: c.dataset.sensitive === "true",
        };
      });

      (window as any).ImageModal.open(images, index);
    });

    // --- Tag filter ---
    let activeTag = "all";

    function applyFilter() {
      allCards().forEach((card) => {
        const tags = (card.dataset.tags || "").split(" ").filter(Boolean);
        card.style.display =
          activeTag === "all" || tags.includes(activeTag) ? "" : "none";
      });
    }

    filterTabs?.addEventListener("click", (e) => {
      const tab = (e.target as HTMLElement).closest(
        ".filter-tab"
      ) as HTMLElement;
      if (!tab) return;

      const tag = tab.dataset.tag!;
      activeTag = activeTag === tag ? "all" : tag;

      filterTabs.querySelectorAll(".filter-tab").forEach((t) => {
        const el = t as HTMLElement;
        const isActive = el.dataset.tag === activeTag;
        el.classList.toggle("active", isActive);
        el.setAttribute("aria-selected", String(isActive));
      });

      applyFilter();
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>

<style>
  .page-title {
    font-size: 2.5rem;
  }

  .caption {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0.25rem 0 0;
  }

  .controls {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin: var(--space-md) 0;
    flex-wrap: wrap;
  }

  .sensitive-checkbox {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    cursor: pointer;
    white-space: nowrap;
    border: 1px solid var(--color-interactive-border);
    border-radius: var(--radius-image);
    padding: 0.375rem 0.75rem;
    transition: border-color var(--transition-fast);
  }

  .sensitive-checkbox:hover {
    border-color: var(--color-interactive-border-hover);
  }

  .sensitive-checkbox:has(input[type="checkbox"]:checked) {
    border-color: var(--color-accent);
  }

  .sensitive-checkbox input[type="checkbox"] {
    accent-color: var(--color-accent);
  }

  /* --- Filter tabs --- */
  .filter-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .filter-tab {
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-interactive-border);
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--color-text);
    font-size: 0.8125rem;
    cursor: pointer;
    transition: background var(--transition-fast), border-color var(--transition-fast);
    font-family: inherit;
  }

  .filter-tab:hover {
    border-color: var(--color-interactive-border-hover);
  }

  .filter-tab.active {
    background: var(--color-accent);
    color: var(--color-accent-text);
    border-color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2rem;
    }
  }
</style>
